{
  "name": "@crowdcircuit/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "lint": "eslint src test drizzle.config.ts",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run",
    "test:declarations": "tsc -p test/tsconfig.declarations.json --noEmit",
    "build": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsc -b --force",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@crowdcircuit/auth-core": "workspace:*",
    "@crowdcircuit/contracts": "workspace:*",
    "drizzle-orm": "1.0.0-rc.4",
    "fastify": "^5.3.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "drizzle-kit": "1.0.0-rc.4",
    "tsx": "^4.20.3"
  }
}
